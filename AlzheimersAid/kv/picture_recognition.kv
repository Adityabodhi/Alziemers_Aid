<PictureRecognitionScreen>:
    name: 'picture_recognition'
    MDBoxLayout:
        orientation: 'vertical'
        padding: "16dp"
        spacing: "12dp"
        
        MDTopAppBar:
            title: "Picture Recognition"
            left_action_items: [["arrow-left", lambda x: setattr(app.root, 'current', 'games_menu')]]
            elevation: 2
            
        MDLabel:
            id: prompt_label
            text: "Tap ..."
            font_style: "H4"
            halign: "center"
            adaptive_height: True

        MDGridLayout:
            id: game_grid
            cols: 2
            spacing: "24dp"
            padding: "24dp"
