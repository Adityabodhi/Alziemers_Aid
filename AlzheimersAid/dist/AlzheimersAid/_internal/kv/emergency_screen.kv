<EmergencyScreen>:
    name: 'emergency'
    MDBoxLayout:
        orientation: 'vertical'
        padding: "16dp"
        spacing: "12dp"
        
        MDTopAppBar:
            title: app.tr("emergency")
            left_action_items: [["arrow-left", lambda x: setattr(app.root, 'current', 'home')]]
            elevation: 2
            
        MDRaisedButton:
            text: "🆘 " + app.tr("emergency_call")
            md_bg_color: 1, 0, 0, 1 # Red
            font_size: "24sp"
            size_hint_x: 1
            height: "80dp"
            on_release: root.emergency_call()

        MDCard:
            orientation: 'vertical'
            padding: "16dp"
            spacing: "8dp"
            size_hint_y: None
            height: "240dp"
            elevation: 1
            
            MDTextField:
                id: contact_name_input
                hint_text: app.tr("name")
                
            MDTextField:
                id: contact_phone_input
                hint_text: app.tr("phone")
                input_filter: "int"
                
            MDRaisedButton:
                text: app.tr("add_contact")
                pos_hint: {"center_x": .5}
                on_release: root.add_contact()

        MDLabel:
            text: app.tr("saved_contacts")
            font_style: "H6"
            adaptive_height: True

        MDScrollView:
            MDList:
                id: contact_list
