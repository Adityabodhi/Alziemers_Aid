<CompanionScreen>:
    name: 'companion'
    MDBoxLayout:
        orientation: 'vertical'
        
        MDBoxLayout:
            size_hint_y: None
            height: "64dp"
            md_bg_color: app.theme_cls.primary_color
            padding: ["8dp", 0, "8dp", 0]
            spacing: "12dp"
            elevation: 2
            
            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                pos_hint: {"center_y": .5}
                on_release: app.root.current = 'home'
                
            MDLabel:
                text: app.translator.translate("companion") if app.lang_code else ""
                halign: "center"
                valign: "middle"
                font_style: "H6"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_name: "Devanagari" if app.lang_code in ["hi", "mr"] else "Roboto"
                bold: True
                
            Widget: # Spacer
                size_hint_x: None
                width: "48dp"
            
        ScrollView:
            id: scroll_view
            MDBoxLayout:
                id: chat_container
                orientation: 'vertical'
                padding: "16dp"
                spacing: "20dp"
                adaptive_height: True
                
                MDLabel:
                    text: root.chat_text
                    halign: "left"
                    font_style: "Body1"
                    adaptive_height: True
                    markup: True

        MDBoxLayout:
            size_hint_y: None
            height: "80dp"
            padding: "12dp"
            spacing: "12dp"
            md_bg_color: app.theme_cls.bg_darkest if app.theme_cls.theme_style == "Dark" else app.theme_cls.bg_light
            
            MDTextField:
                id: user_input
                hint_text: app.tr("ask_anything")
                multiline: False
                mode: "rectangle"
                on_text_validate: root.process_input()
                
            MDIconButton:
                icon: "send"
                theme_text_color: "Custom"
                text_color: app.theme_cls.primary_color
                pos_hint: {"center_y": .5}
                on_release: root.process_input()
