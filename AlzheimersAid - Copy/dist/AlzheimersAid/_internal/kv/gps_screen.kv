#:import MapView kivy_garden.mapview.MapView

<GPSScreen>:
    name: 'gps'
    MDBoxLayout:
        orientation: 'vertical'
        padding: "16dp"
        spacing: "12dp"
        
        MDTopAppBar:
            title: app.tr("location")
            left_action_items: [["arrow-left", lambda x: setattr(app.root, 'current', 'home')]]
            elevation: 2
            
        MDLabel:
            text: app.tr("find_location")
            font_style: "H6"
            adaptive_height: True

        MapView:
            id: mapview
            lat: 19.0760 # Dummy Mumbai lat
            lon: 72.8777 # Dummy Mumbai lon
            zoom: 10

        MDRaisedButton:
            text: app.tr("find_location")
            pos_hint: {"center_x": .5}
            on_release: root.get_location()
