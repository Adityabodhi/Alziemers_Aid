<MemoryMatchScreen>:
    name: 'memory_match'
    MDBoxLayout:
        orientation: 'vertical'
        padding: "16dp"
        spacing: "12dp"
        
        MDTopAppBar:
            title: app.translator.translate("memory_match") if app.lang_code else ""
            left_action_items: [["arrow-left", lambda x: setattr(app.root, 'current', 'games_menu')]]
            elevation: 2
            
        MDLabel:
            text: app.tr("match_prompt")
            halign: "center"
            font_style: "H6"
            adaptive_height: True

        AnchorLayout:
            MDGridLayout:
                id: game_grid
                cols: 4
                spacing: "12dp"
                padding: "12dp"
                adaptive_size: True
